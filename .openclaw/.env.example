# === API Keys ===
# Codex Pro OAuth (1순위 — $200/월 정액, 사무창 운영팀과 공유)
# openclaw onboard --auth-choice openai-codex 로 설정
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# Claude API Key (3순위 fallback — console.anthropic.com에서 발급)
# 주의: OAuth 토큰(sk-ant-sid-xxx) 절대 사용 금지 (Ban 위험)
ANTHROPIC_API_KEY=sk-ant-api01-xxxxxxxxxxxxxxxxxxxxx

# === Telegram Bot Tokens (5개 — @BotFather에서 생성) ===
TELEGRAM_BOT_TOKEN_STRATEGY=123456789:ABC-DEFxxxxx
TELEGRAM_BOT_TOKEN_RESEARCH=123456789:ABC-DEFxxxxx
TELEGRAM_BOT_TOKEN_CONTENT=123456789:ABC-DEFxxxxx
TELEGRAM_BOT_TOKEN_FUNNEL=123456789:ABC-DEFxxxxx
TELEGRAM_BOT_TOKEN_ANALYSIS=123456789:ABC-DEFxxxxx

# === Telegram Group & Topics ===
# 포럼 그룹 ID (Topics 활성화 필수)
TELEGRAM_GROUP_ID=-100xxxxxxxxxx

# 각 에이전트별 토픽 ID (그룹 내 Thread ID)
TOPIC_STRATEGY=xxxxx
TOPIC_RESEARCH=xxxxx
TOPIC_CONTENT=xxxxx
TOPIC_FUNNEL=xxxxx
TOPIC_ANALYSIS=xxxxx

# === Owner ===
# 대표님 개인 Telegram ID (@userinfobot으로 확인)
OWNER_TELEGRAM_ID=xxxxxxxxx
